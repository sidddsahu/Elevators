# .env.local — copy this file and fill values, never commit real secrets

# Site URL
NEXT_PUBLIC_SITE_URL=https://onwardelevators.com

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# WhatsApp number for click-to-chat
NEXT_PUBLIC_WHATSAPP_NUMBER=918001002345

# Email service (e.g. Resend / SendGrid) — server-side only
EMAIL_API_KEY=your_email_api_key_here
EMAIL_FROM=noreply@onwardelevators.com
EMAIL_TO=info@onwardelevators.com

# Sanity CMS (optional — for future CMS integration)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
